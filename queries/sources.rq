PREFIX dct:  <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX lto:  <http://bp4mc2.org/lto#>

SELECT
  ?tech
  ?bron
  ?titel
  ?pagina
  ?verwijzing
WHERE {
  ?tech lto:bron ?bron .

  OPTIONAL { ?bron dct:title ?titel . }
  OPTIONAL { ?bron foaf:page ?pagina . }
  OPTIONAL { ?bron dct:bibliographicCitation ?verwijzing . }
}
ORDER BY ?tech LCASE(STR(COALESCE(?titel, "")))