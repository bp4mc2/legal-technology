{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Module (API)",
            "type": "debugpy",
            "request": "launch",
            "module": "api.routes.app",
            "cwd": "${workspaceFolder}/apps",
            "python": "${workspaceFolder}/apps/.venv/Scripts/python.exe",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/apps",
                "FLASK_DEBUG_TRAP_HTTP": "0"
            },
            "subProcess": false,
            "justMyCode": false
        },
        {
            "name": "Python Debugger: Attach Flask (manual start)",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "127.0.0.1",
                "port": 5678
            },
            "justMyCode": false
        },
        {
            "type": "msedge",
            "request": "launch",
            "name": "Debug Vite App (Edge)",
            "url": "http://localhost:3000",
            "runtimeExecutable": "C:/Program Files (x86)/Microsoft/Edge/Application/msedge.exe",
            "userDataDir": true,
            "preLaunchTask": "Start Frontend",
            "webRoot": "${workspaceFolder}/apps/dashboard",
            "sourceMaps": true
        },
        {
            "type": "msedge",
            "request": "attach",
            "name": "Attach Vite App (Edge, manual)",
            "url": "http://localhost:3000",
            "port": 9222,
            "urlFilter": "http://localhost:3000/*",
            "webRoot": "${workspaceFolder}/apps/dashboard",
            "sourceMaps": true
        },
        {
            "name": "Python Debugger: Module (Gen Documentation)",
            "type": "debugpy",
            "request": "launch",
            "module": "generate_respec",
            "cwd": "${workspaceFolder}/tools",
            "python": "${workspaceFolder}/apps/.venv/Scripts/python.exe",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/tools",
            },
            "subProcess": false,
            "justMyCode": false
        },
    ]
}