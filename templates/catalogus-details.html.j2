<section id="technologieen">
  <h3>Technologieën</h3>

  {% if technologies %}
  {% for tech in technologies %}
  {% set gs = tech.gebruiksstatus if tech.gebruiksstatus else {} %}
  {% set lv = tech.licentievorm if tech.licentievorm else {} %}
  {% set bh = tech.beheerder if tech.beheerder else {} %}
  {% set le = tech.leverancier if tech.leverancier else {} %}
  {% set ns = tech.normstatus if tech.normstatus else {} %}
  {% set tt = tech.typeTechnologie if tech.typeTechnologie else {} %}
  {% set gg = tech.gebruikersgroepen if tech.gebruikersgroepen else [] %}
  {% set fv = tech.functionaliteiten if tech.functionaliteiten else [] %}
  {% set has_beheerder = bh and (bh.naam or bh.contactinformatie) %}
  {% set has_leverancier = le and (le.naam or le.contactinformatie) %}

  <section id="{{ tech.anchor }}" class="lt-card">
    <h4>{{ tech.naam | default(tech.id) }}</h4>
    <p class="lt-heading-meta">
      {% if tech.typeLabel %}
      <span class="lt-badge lt-badge--type">{{ tech.typeLabel }}</span>
      {% else %}
      <span class="lt-leeg">Niet opgenomen</span>
      {% endif %}
      {% if gs.label or gs.id %}
      <span class="lt-badge lt-badge--status">{{ gs.label | default(gs.id) }}</span>
      {% else %}
      <span class="lt-leeg">Niet opgenomen</span>
      {% endif %}
      {% if lv.label or lv.id %}
      <span class="lt-badge lt-badge--licentie">{{ lv.label | default(lv.id) }}</span>
      {% else %}
      <span class="lt-leeg">Niet opgenomen</span>
      {% endif %}
    </p>

    <p class="lt-sectie-label">Identificatie</p>
    <dl class="lt-meta">

      <dt>Versie</dt>
      <dd>
        {% if tech.versienummer or tech.versiedatum %}
        {{ tech.versienummer | default('') }}{% if tech.versiedatum %} ({{ tech.versiedatum }}){% endif %}
        {% else %}
        <span class="lt-leeg">Niet opgenomen</span>
        {% endif %}
      </dd>

      <dt>Bijgewerkt op</dt>
      <dd>
        {% if tech.bijgewerktOp %}
        {{ tech.bijgewerktOp }}
        {% else %}
        <span class="lt-leeg">Niet opgenomen</span>
        {% endif %}
      </dd>

      {% if tech.typeLabel == "Standaard" %}
      <dt>Normstatus</dt>
      <dd>
        {% if ns.label or ns.id %}
        {{ ns.label | default(ns.id) }}
        {% else %}
        <span class="lt-leeg">Niet opgenomen</span>
        {% endif %}
      </dd>
      {% endif %}

      {% if tech.typeLabel == "Tool" %}
      <dt>Type technologie</dt>
      <dd>
        {% if tt.label or tt.id %}
        {{ tt.label | default(tt.id) }}
        {% else %}
        <span class="lt-leeg">Niet opgenomen</span>
        {% endif %}
      </dd>
      {% endif %}

      <dt>URI</dt>
      <dd>
        {% if tech.uri %}
        <a class="lt-uri" href="{{ tech.uri }}">{{ tech.uri }}</a>
        {% else %}
        <span class="lt-leeg">Niet opgenomen</span>
        {% endif %}
      </dd>
    </dl>

    <p class="lt-sectie-label">Gebruiksgroepen</p>
    {% if gg %}
    <ul class="lt-tags" role="list">
      {% for group in gg %}
      <li class="lt-tag">{{ group.label | default(group.id | default(group.value | default(group))) }}</li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="lt-leeg">Geen gebruiksgroepen opgenomen.</p>
    {% endif %}

    <p class="lt-sectie-label">Functionaliteiten</p>
    {% if fv %}
    <ul class="lt-tags" role="list">
      {% for func in fv %}
      <li class="lt-tag">{{ func.label | default(func.id | default(func.value | default(func))) }}</li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="lt-leeg">Geen functionaliteiten opgenomen.</p>
    {% endif %}

    <p class="lt-sectie-label">Omschrijving</p>
    {% if tech.omschrijving %}
    <p>{{ tech.omschrijving }}</p>
    {% else %}
    <p class="lt-leeg">Geen omschrijving opgenomen.</p>
    {% endif %}

    <p class="lt-sectie-label">Waarde en onderdelen</p>
    {% if tech.documentatie %}
    {% for doc in tech.documentatie %}
    <div class="lt-documentatie">
      {% if doc.toegevoegdeWaarde %}
      <p class="lt-documentatie__waarde">{{ doc.toegevoegdeWaarde }}</p>
      {% endif %}

      {% if doc.onderdelen %}
      <p class="lt-documentatie__onderdelen"><strong>Onderdelen:</strong> {{ doc.onderdelen }}</p>
      {% endif %}

      {% if doc.ontwikkelingEnBeheer %}
      <p class="lt-documentatie__onderdelen"><strong>Ontwikkeling en beheer:</strong> {{ doc.ontwikkelingEnBeheer }}</p>
      {% endif %}
    </div>
    {% endfor %}
    {% else %}
    <p class="lt-leeg">Geen aanvullende documentatie beschikbaar.</p>
    {% endif %}

    <p class="lt-sectie-label">Toepassing</p>

    <p class="lt-sectie-label">Taken</p>
    <table class="lt-tabel">
      <thead>
        <tr>
          <th scope="col">Taaktype</th>
          <th scope="col">Omschrijving</th>
        </tr>
      </thead>
      <tbody>
        {% if tech.taken %}
        {% for taak in tech.taken %}
        <tr>
          <td>{{ taak.taaktype.label | default(taak.taaktype.id | default(taak.taaktype | default(''))) }}</td>
          <td>{{ taak.taak_omschrijving | default('') }}</td>
        </tr>
        {% endfor %}
        {% else %}
        <tr>
          <td colspan="2"><span class="lt-leeg">Geen taken opgenomen.</span></td>
        </tr>
        {% endif %}
      </tbody>
    </table>

    <p class="lt-sectie-label">Ondersteuningsvormen</p>
    <table class="lt-tabel">
      <thead>
        <tr>
          <th scope="col">Beschouwingsniveau</th>
          <th scope="col">Modelsoort</th>
        </tr>
      </thead>
      <tbody>
        {% if tech.ondersteuningsvormen %}
        {% for ov in tech.ondersteuningsvormen %}
        <tr>
          <td>{{ ov.beschouwingsniveau.label | default(ov.beschouwingsniveau.id | default(ov.beschouwingsniveau | default(''))) }}</td>
          <td>{{ ov.modelsoort.label | default(ov.modelsoort.id | default(ov.modelsoort | default(''))) }}</td>
        </tr>
        {% endfor %}
        {% else %}
        <tr>
          <td colspan="2"><span class="lt-leeg">Geen ondersteuningsvormen opgenomen.</span></td>
        </tr>
        {% endif %}
      </tbody>
    </table>

    <p class="lt-sectie-label">Organisatie</p>

    {% if has_beheerder %}
    <p class="lt-sectie-label">Beheerder</p>
    <dl class="lt-meta">
      <dt>Organisatie</dt>
      <dd>{{ bh.naam | default('') }}</dd>
      <dt>Contact</dt>
      <dd>
        {% if bh.contactinformatie %}
        <a href="mailto:{{ bh.contactinformatie }}">{{ bh.contactinformatie }}</a>
        {% else %}
        <span class="lt-leeg">Niet opgenomen</span>
        {% endif %}
      </dd>
    </dl>
    {% endif %}

    {% if has_leverancier %}
    <p class="lt-sectie-label">Leverancier</p>
    <dl class="lt-meta">
      <dt>Organisatie</dt>
      <dd>{{ le.naam | default('') }}</dd>
      <dt>Contact</dt>
      <dd>
        {% if le.contactinformatie %}
        <a href="mailto:{{ le.contactinformatie }}">{{ le.contactinformatie }}</a>
        {% else %}
        <span class="lt-leeg">Niet opgenomen</span>
        {% endif %}
      </dd>
    </dl>
    {% endif %}

    {% if not has_beheerder and not has_leverancier %}
    <p class="lt-leeg">Geen organisatiegegevens opgenomen.</p>
    {% endif %}

    <p class="lt-sectie-label">Bronnen</p>
    {% if tech.bronnen %}
    <ul class="lt-bronnen">
      {% for bron in tech.bronnen %}
      <li>
        {% if bron.bron_locatie %}
        <a href="{{ bron.bron_locatie }}">{{ bron.bron_titel | default(bron.bron_locatie) }}</a>{% if bron.bron_verwijzing %} — {{ bron.bron_verwijzing }}{% endif %}
        {% else %}
        {{ bron.bron_titel | default('Onbekende bron') }}{% if bron.bron_verwijzing %} — {{ bron.bron_verwijzing }}{% endif %}
        {% endif %}
      </li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="lt-leeg">Geen bronnen opgenomen.</p>
    {% endif %}
  </section>
  {% endfor %}
  {% else %}
  <p>Er zijn geen technologie-details gevonden.</p>
  {% endif %}
</section>
