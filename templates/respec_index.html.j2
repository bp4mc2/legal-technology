<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8">
  <title>{{ metadata.title or "Documentatie juridische technologie" }}</title>

  <script class="remove">
    var respecConfig = {
      specStatus: "base",
      shortName: "juridische-technologie",
      editors: [
        {
          name: "{{ metadata.creator or 'Onbekend' }}"
        }
      ],
      maxTocLevel: 2
    };
  </script>

  <script
    src="https://www.w3.org/Tools/respec/respec-w3c"
    class="remove"
    async></script>
</head>

<body>
  <section id="abstract">
    <p>
      Deze documentatie beschrijft juridische technologieën, taxonomieën,
      organisaties en de onderliggende ontologie.
    </p>
  </section>

  <section id="sotd">
    <p>
      Gegenereerd op {{ generated_on }}.
    </p>
  </section>

  <section>
    <h2>Startpunt</h2>

    <p>
      Gebruik deze pagina als ingang tot de documentatie. De inhoud is
      opgesplitst in deelpagina’s zodat de documentatie beter leesbaar en
      navigeerbaar blijft.
    </p>

    <ul>
      {% for page in pages %}
      <li>
        <a href="{{ page.output_file }}">{{ page.title }}</a>
        — {{ page.description }}
      </li>
      {% endfor %}
    </ul>
  </section>

  <section id="aandachtspunten"
     data-include="{{ aandachtspunten }}"
     data-include-format="markdown">
  </section>

  <section id="summary"
     data-include="{{ generation_justification }}"
     data-include-format="markdown">
  </section>
    
</body>
</html>
