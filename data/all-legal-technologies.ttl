<https://data.bp4mc2.org/id/lto/legaltech/bpmn/v/1.0> lto:beschrijving <https://data.bp4mc2.org/id/lto/legaltech/bpmn/v/1.0/documentatie/7a5b45a4-27a9-4312-b309-1016c1c502dc> ;
	lto:bijgewerktOp "2026-04-14"^^xsd:date ;
	lto:bron <https://data.bp4mc2.org/id/lto/legaltech/bpmn/v/1.0/bronverwijzing/a98e4caa-74c9-42b6-9239-043a1bd502b0> ;
	lto:gebruiksstatus lt:InGebruik ;
	lto:geschiktVoorTaak <https://data.bp4mc2.org/id/lto/legaltech/bpmn/v/1.0/taakinvulling/0620e3da-8a11-4470-91cb-c22377588d1d>, <https://data.bp4mc2.org/id/lto/legaltech/bpmn/v/1.0/taakinvulling/2722ff64-dd3a-4058-952f-7f79d7e44063> ;
	lto:licentievorm lt:VolledigOpen ;
	lto:naam "BPMN - Business Process Model and Notation" ;
	lto:omschrijving "Business Process Model and Notation (BPMN) is een grafische standaard voor het modelleren en vastleggen van bedrijfsprocessen. De standaard is oorspronkelijk ontwikkeld door de Business Process Management Initiative (BPMI) en wordt sinds 2005 beheerd door de Object Management Group (OMG). Met BPMN 2.0 zijn naast notatie‑ en diagramregels ook uitvoeringssemantiek geïntroduceerd. BPMN is vastgelegd als OMG‑specificatie en tevens genormeerd als ISO 19510." ;
	lto:versiebeschrijving _:r11 ;
	rdf:type lto:Standaard ;
	rdfs:label "BPMN - Business Process Model and Notation"@nl .

<https://data.bp4mc2.org/id/lto/legaltech/bpmn/v/1.0/bronverwijzing/a98e4caa-74c9-42b6-9239-043a1bd502b0> rdf:type lto:Bronverwijzing .

