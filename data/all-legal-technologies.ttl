	lto:onderdelen "Ontologie (conceptueel model in RDF), Thesauri (begrippenlijsten, taxonomieën), Waardelijsten (geversioneerde subsets)"^^xsd:markdown ;
	lto:toegevoegdeWaarde "Gemeenschappelijke “taal” voor overheidssystemen, Betere vindbaarheid en interoperabiliteit (FAIR), Persistente identifiers (URI’s) voor concepten en organisaties"^^xsd:markdown ;
	rdf:type lto:Documentatie .

