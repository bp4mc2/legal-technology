<https://data.bp4mc2.org/id/lto/legaltech/drools/v/1.0> lto:beschrijving <https://data.bp4mc2.org/id/lto/legaltech/drools/v/1.0/documentatie/84b9426f-7da7-47c2-9b8d-e09e6b552ad8> ;
	lto:bijgewerktOp "2026-04-14"^^xsd:date ;
