@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix skosthes: <http://purl.org/iso25964/skos-thes#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.

@prefix ltt: <http://bp4mc2.org/ltt#>. # Legal technology task (types)

ltt:BegrippenkaderTaken a skos:ConceptScheme;
  rdfs:label "Taken"@nl;
  rdfs:label "Tasks"@en;
  skos:prefLabel "Taken"@nl;
  skos:definition "Begrippenkader met alle mogelijke taken"@nl
.

##
## Bovenliggend Taak begrip
##
ltt:Taak a skos:Concept;
  rdfs:label "Taak"@nl;
  skos:prefLabel "Taak"@nl;
  skos:inScheme ltt:BegrippenkaderTaken;
  skos:definition "Een taak is een activiteit die wordt uitgevoerd als onderdeel van het juridisch werkproces"@nl;
.

##
## Taken
##
ltt:OpstellenRegeltekst a skos:Concept;
  rdfs:label "Opstellen regeltekst"@nl;
  skos:prefLabel "Opstellen regeltekst"@nl;
  skos:inScheme ltt:BegrippenkaderTaken;
  skos:altLabel "Drafting legislation"@en;
  skos:definition "Opstellen regeltekst is een taak waarbij tekst wordt opgesteld als onderdeel van het geschreven recht";
  skos:scopeNote "Het gaat hier zowel om algemeen verbindende voorwaarden (Wet in formele zin, AmvB's, Ministeriële regelingen), beleidsregels (zoals bedoeld in de Awb) en ook (intern) geschreven uitvoeringsbeleid.";
  skos:editorialNote "Nog af te stemmen: omvat het ook de wet in formele zin, en wat is de reikwijdte: waar begint opstellen regeltekst (valt de beleidsvorming er ook onder) en waar eindigt opstellen regeltekst (valt het vaststellings- en publicatieproces er ook onder)?";
  skosthes:broaderGeneric ltt:Taak;
.

ltt:Opdrachtorientering a skos:Concept;
  rdfs:label "Opdracht orientering"@nl;
  skos:prefLabel "Opdracht orientering"@nl;
  skos:inScheme ltt:BegrippenkaderTaken;
  skos:altLabel "Scope definition"@en;
  skos:definition "Afbakenen reikwijdte is een taak waarin wordt bepaald waaruit de opgave bestaat";
  skos:scopeNote "Een 'opgave' kan gelezen worden als het doel waarvoor de wetgeving c.q. wetsuitvoering is bedoeld, en het effect dat hiermee wordt beoogd";
  skosthes:broaderGeneric ltt:Taak;
.

ltt:VerzamelenBronmateriaal a skos:Concept;
  rdfs:label "Verzamelen bronmateriaal"@nl;
  skos:prefLabel "Verzamelen bronmateriaal"@nl;
  skos:inScheme ltt:BegrippenkaderTaken;
  skos:altLabel "Acquire source material"@en;
  skos:definition "Verzamelen bronmateriaal is een taak waarin de relevante bronnen worden verzameld die nodig zijn voor de gegeven opgave";
  skos:scopeNote "Het gaat hier om de bronnen van het positieve recht, het geschreven recht (zowel intern, nationaal als internationaal), inclusief uitspraken van rechters (jurisprudentie), parlementaire geschiedenis, toelichtingen en annotaties vanuit de rechtswetenschap";
  skos:editorialNote "Mogelijk nog aandacht voor het ongeschreven recht: gewoonte recht en algemene rechtsbeginselen. Deze kunnen niet echt als bronmateriaal worden gezien, maar kunnen mogelijk wel bijdragen, mits er iets van op papier staat?";
  skosthes:broaderGeneric ltt:Taak;
.

ltt:AnalyserenRegeltekst a skos:Concept;
  rdfs:label "Analyseren regeltekst"@nl;
  skos:prefLabel "Analyseren regeltekst"@nl;
  skos:inScheme ltt:BegrippenkaderTaken;
  skos:definition "Analyseren is een taak waarin op een gestructureerde manier de betekenis, structuur en bedoeling van een juridische tekst wordt onderzocht";
  skos:scopeNote "Interpreteren van een juridische tekst valt expliciet niet onder deze taak. De analyse beoogd een zo feitelijk mogelijk onderzoek";
  skosthes:broaderGeneric ltt:Taak;
.

ltt:InterpreterenEnExpliciteren a skos:Concept;
  skos:inScheme ltt:BegrippenkaderTaken;
  rdfs:label "Interpreteren en expliciteren"@nl;
  skos:prefLabel "Interpreteren en expliciteren"@nl;  
  skos:definition "Het interpreteren van een juridische tekst en de betekenis en bedoeling daarvan op een gestructureerde manier vastleggen.";
  skos:scopeNote "Dit lijkt op rechtsvinding (en ook rechtsvorming (!)), maar is in dit geval niet bedoeld voor een individueel geval.";
  skosthes:broaderGeneric ltt:Taak;
.

ltt:BegripDefinieren a skos:Concept;
  skos:inScheme ltt:BegrippenkaderTaken;
  rdfs:label "Begrip definiëren"@nl;
  skos:prefLabel "Begrip definiëren"@nl;
  skos:definition "Het gestructureerd beschrijven van de betekenis die met een term wordt bedoeld in een specifieke context.";
  skosthes:broaderGeneric ltt:Taak;
.

ltt:SpecificerenGegevensbehoefte a skos:Concept;
  skos:inScheme ltt:BegrippenkaderTaken;
  rdfs:label "Specificeren gegevens(behoefte)"@nl;
  skos:prefLabel "Specificeren gegevens(behoefte)"@nl;
  skos:definition "Het uitvoerbaar maken van wet- en regelgeving door te specificeren welke gegevens nodig zijn ten behoeve van een wettelijke taak.";
  skosthes:broaderGeneric ltt:Taak;
.

ltt:SpecificerenRegels a skos:Concept;
  skos:inScheme ltt:BegrippenkaderTaken;
  rdfs:label "Specificeren regels"@nl;
  skos:prefLabel "Specificeren regels"@nl;
  skos:definition "Het uitvoerbaar maken van wet- en regelgeving door te specificeren welke regels nodig zijn ten behoeve van een wettelijke taak.";
  skos:scopeNote "Met \"regel\" wordt hier een regel bedoeld in de vorm van een algoritme of functie die op basis van aangeboden gegevens komt tot een resultaat (in de vorm van gegevens).";
  skosthes:broaderGeneric ltt:Taak;
.

ltt:SpecificerenProcessen a skos:Concept;
  skos:inScheme ltt:BegrippenkaderTaken;
  rdfs:label "Specificeren processen"@nl;
  skos:prefLabel "Specificeren processen"@nl;
  skos:definition "Het uitvoerbaar maken van wet- en regelgeving door te specificeren welke processen uitgevoerd moeten worden ten behoeve van een wettelijke taak.";
  skosthes:broaderGeneric ltt:Taak;
.

ltt:ValiderenSpecificaties a skos:Concept;
  skos:inScheme ltt:BegrippenkaderTaken;
  rdfs:label "Valideren specificaties"@nl;
  skos:prefLabel "Valideren specificaties"@nl;
  skos:definition "Het valideren of (gegevens, regel en/of proces-)specificaties overeen komen met de juridische teksten en de interpretatie die aan deze teksten moet worden gegeven.";
  skosthes:broaderGeneric ltt:Taak
.

ltt:ImplementerenSpecificaties a skos:Concept;
  skos:inScheme ltt:BegrippenkaderTaken;
  rdfs:label "Implementeren specificaties"@nl;
  skos:prefLabel "Implementeren specificaties"@nl;
  skos:definition "Het implementeren van specificaties in een geautomatiseerde regeluitvoering of beslisondersteuning.";
  skosthes:broaderGeneric ltt:Taak
.

ltt:GeautomatiseerdeRegeluitvoering a skos:Concept;
  skos:inScheme ltt:BegrippenkaderTaken;
  rdfs:label "Geautomatiseerde regeluitvoering"@nl;
  skos:prefLabel "Geautomatiseerde regeluitvoering"@nl;
  skos:definition "Het geautomatiseerd uitvoeren van regels, of delen van regels, zonder menselijke tussenkomst.";
  skosthes:broaderGeneric ltt:Taak
.

ltt:Beslisondersteuning a skos:Concept;
  skos:inScheme ltt:BegrippenkaderTaken;
  rdfs:label "Beslisondersteuning"@nl;
  skos:prefLabel "Beslisondersteuning"@nl;
  skos:definition "Het ondersteunen van besluitvorming door het verstrekken van relevante informatie en analyses.";
  skosthes:broaderGeneric ltt:Taak
.

ltt:Evaluatie a skos:Concept;
  skos:inScheme ltt:BegrippenkaderTaken;
  rdfs:label "Evaluatie"@nl;
  skos:prefLabel "Evaluatie"@nl;
  skos:definition "Het gestructureerd beoordelen of de implementatie en uitvoering van wet- en regelgeving in de praktijk overeenkomen met de met de beleidsdoelen beoogde effecten.";
  skosthes:broaderGeneric ltt:Taak
.

##
## Taakgroepen
##
ltt:Groep1 a skos:OrderedCollection;
  rdfs:label "Taakgroep 1";
  skos:prefLabel "Taakgroep 1 - Tekstuele analyse en interpretatie"@nl;
  skos:memberList (
    ltt:OpstellenRegeltekst
    ltt:Opdrachtorientering
    ltt:VerzamelenBronmateriaal
  )
.
ltt:Groep2 a skos:OrderedCollection;
  rdfs:label "Taakgroep 2";
  skos:prefLabel "Taakgroep 2 - Analyse en interpretatie"@nl;
  skos:memberList (
    ltt:AnalyserenRegeltekst
    ltt:InterpreterenEnExpliciteren
    ltt:BegripDefinieren
  )
.
ltt:Groep3 a skos:OrderedCollection;
  rdfs:label "Taakgroep 3";
  skos:prefLabel "Taakgroep 3 - Specificeren/Modelleren"@nl;
  skos:memberList (
    ltt:SpecificerenGegevensbehoefte
    ltt:SpecificerenRegels
    ltt:SpecificerenProcessen
  )
.
ltt:Groep4 a skos:OrderedCollection;
  rdfs:label "Taakgroep 4";
  skos:prefLabel "Taakgroep 4 - Validatie en uitvoering"@nl;
  skos:memberList (
    ltt:ValiderenSpecificaties
    ltt:GeautomatiseerdeRegeluitvoering
    ltt:Beslisondersteuning
    ltt:Evaluatie
  )
.

##
## Opvolging van taken
##
ltt:volgtOp a owl:ObjectProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range skos:Concept ;
  rdfs:label "volgt op"@nl .

# Volgorde van taken binnen een taakgroep
# Taakgroep 1
ltt:Opdrachtorientering ltt:volgtOp ltt:OpstellenRegeltekst .
ltt:VerzamelenBronmateriaal ltt:volgtOp ltt:Opdrachtorientering .

# Taakgroep 2
ltt:AnalyserenRegeltekst ltt:volgtOp ltt:VerzamelenBronmateriaal .
ltt:InterpreterenEnExpliciteren ltt:volgtOp ltt:AnalyserenRegeltekst .
ltt:BegripDefinieren ltt:volgtOp ltt:InterpreterenEnExpliciteren .

# Taakgroep 3
ltt:SpecificerenGegevensbehoefte ltt:volgtOp ltt:BegripDefinieren .
ltt:SpecificerenRegels ltt:volgtOp ltt:SpecificerenGegevensbehoefte .
ltt:SpecificerenProcessen ltt:volgtOp ltt:SpecificerenRegels .

# Taakgroep 4
ltt:ValiderenSpecificaties ltt:volgtOp ltt:SpecificerenProcessen .
ltt:ImplementerenSpecificaties ltt:volgtOp ltt:ValiderenSpecificaties .
ltt:GeautomatiseerdeRegeluitvoering ltt:volgtOp ltt:ImplementerenSpecificaties .
ltt:Beslisondersteuning ltt:volgtOp ltt:ImplementerenSpecificaties .
ltt:Evaluatie ltt:volgtOp ltt:GeautomatiseerdeRegeluitvoering, ltt:Beslisondersteuning .

# loop
ltt:Evaluatie ltt:volgtOp ltt:GeautomatiseerdeRegeluitvoering .
ltt:Opdrachtorientering ltt:volgtOp ltt:Evaluatie .