.

lto:SysteemWaarbinnenDeRegelsWordenUitgevoerd a skos:Concept;
  rdfs:label "Systeem waarbinnen de regels worden uitgevoerd"@nl;
  skos:prefLabel "Systeem waarbinnen de regels worden uitgevoerd"@nl;
