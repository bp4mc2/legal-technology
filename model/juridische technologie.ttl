lt:Wettelijk a skos:Concept;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:prefLabel "Wettelijk"@nl.

# SHACL shape for normstatussen
lto:NormstatussenShape a sh:NodeShape;
  rdfs:label "Normstatussen";
  sh:property [
    sh:path [sh:inversePath skos:member];
    sh:hasValue lto:Normstatussen
  ]
.

##
## Beschouwingsniveaus enumeration
##
lto:Beschouwingsniveaus a skos:Collection;
  rdfs:label "Beschouwingsniveaus"@nl;
  skos:prefLabel "Beschouwingsniveaus"@nl;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:definition "Enumeratie van mogelijke beschouwingsniveaus voor juridische technologie."@nl;
  skos:member lto:Tekstueel, lto:Semantisch, lto:Ontologisch, lto:Logisch, lto:Technisch
.

lto:Tekstueel a skos:Concept;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:prefLabel "Tekstueel"@nl.

lto:Semantisch a skos:Concept;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:prefLabel "Semantisch"@nl.

lto:Ontologisch a skos:Concept;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:prefLabel "Ontologisch"@nl.

lto:Logisch a skos:Concept;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:prefLabel "Logisch"@nl.

lto:Technisch a skos:Concept;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:prefLabel "Technisch"@nl.

# SHACL shape for beschouwingsniveaus
lto:BeschouwingsniveausShape a sh:NodeShape;
  rdfs:label "Beschouwingsniveaus";
  sh:property [
    sh:path [sh:inversePath skos:member];
    sh:hasValue lto:Beschouwingsniveaus
  ]
.

##
## Modelsoorten enumeration
##
lto:Modelsoorten a skos:Collection;
  rdfs:label "Modelsoorten"@nl;
  skos:prefLabel "Modelsoorten"@nl;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:definition "Enumeratie van mogelijke modelsoorten voor juridische technologie."@nl;
  skos:member lto:Descriptief, lto:Normatief
.

lto:Descriptief a skos:Concept;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:prefLabel "Descriptief"@nl.

lto:Normatief a skos:Concept;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:prefLabel "Normatief"@nl.

# SHACL shape for modelsoorten
lto:ModelsoortenShape a sh:NodeShape;
  rdfs:label "Modelsoorten";
  sh:property [
    sh:path [sh:inversePath skos:member];
    sh:hasValue lto:Modelsoorten
  ]
.

# SHACL shape for taaktypen
lto:TaaktypenShape a sh:NodeShape;
  sh:name "Taaktypen";
  sh:property [
    sh:path skos:inScheme;
    sh:hasValue ltt:BegrippenkaderTaken
  ]
.

# SHACL shape for taak-productrelaties
lto:TaakProductRelatiesShape a sh:NodeShape;
  sh:name "Taak-productrelaties";
  rdfs:comment "Valideert taak-productrelaties vanuit de canonieke product-naar-taak opslag via inverse paths."@nl;
  sh:targetObjectsOf lto:inputVoorTaak;
  sh:targetObjectsOf lto:outputVanTaak;
  sh:property [
    sh:path skos:inScheme;
    sh:hasValue ltt:BegrippenkaderTaken
  ];
  sh:property [
    sh:path [ sh:inversePath lto:inputVoorTaak ];
    sh:node lto:ProductenShape
  ];
  sh:property [
    sh:path [ sh:inversePath lto:outputVanTaak ];
    sh:node lto:ProductenShape
  ]
.

# Relatietypen enumeration
lto:Relatietypen a skos:Collection;
  rdfs:label "Relatietypen"@nl;
  skos:prefLabel "Relatietypen"@nl;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:definition "Enumeratie van mogelijke relatietypen tussen juridische technologieën."@nl;
  skos:member lt:Vervangt, lt:VervolgOp, lt:AlternatiefVoor, lt:GerelateerdAan
.

lt:Vervangt a skos:Concept;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:prefLabel "Vervangt"@nl.

lt:VervolgOp a skos:Concept;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:prefLabel "Vervolg op"@nl.

lt:AlternatiefVoor a skos:Concept;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:prefLabel "Alternatief voor"@nl.

lt:GerelateerdAan a skos:Concept;
  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:prefLabel "Gerelateerd aan"@nl.

# SHACL shape for relatietypen
  lto:RelatietypenShape a sh:NodeShape;
  rdfs:label "Relatietypen";
  sh:property [
    sh:path [sh:inversePath skos:member];
    sh:hasValue lto:Relatietypen
  ]
.

