##
## Functionaliteiten enumeration
##
# lto:Functionaliteiten a skos:Collection;
#   rdfs:label "Functionaliteiten"@nl;
#   skos:prefLabel "Functionaliteiten"@nl;
#   skos:inScheme lt:BegrippenkaderCategorieen;
#   skos:definition "Enumeratie van mogelijke functionaliteiten voor juridische technologie."@nl;
#   skos:member lt:GeautomatiseerdBeslissen, lt:ComplianceOndersteuning
# .

lto:Functionaliteiten a skos:Collection ;
  rdfs:label "Functionaliteiten"@nl ;
  skos:prefLabel "Functionaliteiten"@nl ;
  skos:definition "Enumeratie van mogelijke functionaliteiten voor juridische technologie."@nl ;
  skos:member
    lt:GeautomatiseerdBeslissen,
    lt:ComplianceOndersteuning,
    lt:ContractAutomatischAanmaken,
    lt:ContractAnalyticsConceptReview,
    lt:JuridischExpertSysteem,
    lt:WetgevingConceptualisering,
    lt:WetgevingUitvoering,
    lt:WetgevingRepresentatie,
    lt:LitigatieAnalytics,
    lt:LitigatieConceptualisering,
    lt:LitigatiePredictieVoorsluiting,
    lt:ZoekenRechtspraak,
    lt:ZoekenWetgeving
.

lt:GeautomatiseerdBeslissen a skos:Concept ;
  skos:inScheme lt:BegrippenkaderCategorieen ;
  # skos:prefLabel "Automated decision-making"@en ;
  skos:prefLabel "Geautomatiseerd beslissen"@nl ;
  skos:definition "Het (geheel of gedeeltelijk) nemen van besluiten door een geautomatiseerd systeem, al dan niet met rechtsgevolgen voor betrokkenen."@nl
.

lt:ComplianceOndersteuning a skos:Concept ;
  skos:inScheme lt:BegrippenkaderCategorieen ;
  # skos:prefLabel "Compliance supporCompliancet"@en ;
  skos:prefLabel "Compliance ondersteuning"@nl ;
  skos:altLabel "Compliance-ondersteuning"@nl ;
  skos:definition "Ondersteuning bij het aantoonbaar naleven van wet- en regelgeving en interne normen, inclusief controles, signalering en rapportage."@nl
.

lt:ContractAutomatischAanmaken a skos:Concept ;
  skos:inScheme lt:BegrippenkaderCategorieen ;
  # skos:prefLabel "Contract: automated creation"@en ;
  skos:prefLabel "Contract: geautomatiseerde contractgeneratie"@nl ;
  skos:altLabel "Contract: geautomatiseerde totstandkoming van contracten"@nl ;
  skos:altLabel "Contract: geautomatiseerd opstellen van contracten"@nl ;
  skos:definition "Het automatisch genereren of samenstellen van een contract op basis van invoer, templates en/of clausulebibliotheken."@nl
.

lt:ContractAnalyticsConceptReview a skos:Concept ;
  skos:inScheme lt:BegrippenkaderCategorieen ;
  # skos:prefLabel "Contract: analytics/drafting/review"@en ;
  skos:prefLabel "Contract: analyse/redactie/beoordeling"@nl ;
  skos:altLabel "Contract: analyse, opstellen en beoordeling"@nl ;
  skos:definition "Functionaliteiten voor het analyseren van contractinhoud, het (mede) opstellen/redigeren van bepalingen en het beoordelen (review) van concepten en wijzigingen."@nl
.

lt:JuridischExpertSysteem a skos:Concept ;
  skos:inScheme lt:BegrippenkaderCategorieen ;
  # skos:prefLabel "Legal expert system"@en ;
  skos:prefLabel "Juridisch expertsysteem"@nl ;
  skos:altLabel "Rechtskundig expertsysteem"@nl ;
  skos:definition "Een systeem dat juridische kennis (regels en/of heuristieken) toepast om te adviseren, te kwalificeren of beslissingen/uitkomsten te ondersteunen."@nl
.

lt:WetgevingConceptualisering a skos:Concept ;
  skos:inScheme lt:BegrippenkaderCategorieen ;
  # skos:prefLabel "Legislation: drafting"@en ;
  skos:prefLabel "Wetgeving: wetgevingsredactie"@nl ;
  skos:altLabel "Wetgeving: ontwerpen"@nl ;
  skos:definition "Het (ondersteunen bij het) opstellen en redigeren van wet- en regelgeving, inclusief structuur, definities, verwijzingen en consistentie."@nl
.

lt:WetgevingUitvoering a skos:Concept ;
  skos:inScheme lt:BegrippenkaderCategorieen ;
  # skos:prefLabel "Legislation: execution"@en ;
  skos:prefLabel "Wetgeving: uitvoering van wet- en regelgeving"@nl ;
  skos:altLabel "Wetgeving: implementatie van wet- en regelgeving"@nl ;
  skos:altLabel "Wetgeving: handhaving van wet- en regelgeving"@nl ;
  skos:definition "Functionaliteiten gericht op uitvoering of implementatie van wettelijke verplichtingen en, waar bedoeld, ondersteuning bij toezicht en handhaving."@nl
.

lt:WetgevingRepresentatie a skos:Concept ;
  skos:inScheme lt:BegrippenkaderCategorieen ;
  # skos:prefLabel "Legislation: representation"@en ;
  skos:prefLabel "Wetgeving: modellering van wet- en regelgeving"@nl ;
  skos:altLabel "Wetgeving: representatie"@nl ;
  skos:altLabel "Wetgeving: weergave van wet- en regelgeving"@nl ;
  skos:definition "Het formaliseren of modelleren van wet- en regelgeving (bijv. als regels, logica, metadata of semantische structuur) ten behoeve van interpretatie, toepassing of automatisering."@nl
.

lt:LitigatieAnalytics a skos:Concept ;
  skos:inScheme lt:BegrippenkaderCategorieen ;
  # skos:prefLabel "Litigation: analytics"@en ;
  skos:prefLabel "Procespraktijk: procesanalyse"@nl ;
  skos:altLabel "Litigatiebehandeling: analytics"@nl ;
  skos:definition "Analyse van procesvoering en procesgegevens (bijv. doorlooptijden, uitkomsten, proceshandelingen en patronen) ter ondersteuning van processtrategie en dossiersturing."@nl
.

lt:LitigatieConceptualisering a skos:Concept ;
  skos:inScheme lt:BegrippenkaderCategorieen ;
  # skos:prefLabel "Litigation: drafting"@en ;
  skos:prefLabel "Procespraktijk: opstellen van processtukken"@nl ;
  skos:altLabel "Litigatiebehandeling: conceptualisering"@nl ;
  skos:definition "Het opstellen en redigeren van processtukken (zoals dagvaarding, verzoekschrift, conclusie, pleitnota en incidentele verzoeken)."@nl
.

lt:LitigatiePredictieVoorsluiting a skos:Concept ;
  skos:inScheme lt:BegrippenkaderCategorieen ;
  # skos:prefLabel "Litigation: prediction of judgment"@en ;
  skos:prefLabel "Procespraktijk: voorspelling van rechterlijke uitspraak"@nl ;
  skos:altLabel "Litigatiebehandeling: voorsluiting voorspelling"@nl ;
  skos:definition "Het (statistisch of modelmatig) voorspellen van de waarschijnlijke uitkomst van een procedure of de inhoud/strekking van een rechterlijke uitspraak."@nl
.

lt:ZoekenRechtspraak a skos:Concept ;
  skos:inScheme lt:BegrippenkaderCategorieen ;
  # skos:prefLabel "Search: case law"@en ;
  skos:prefLabel "Zoeken: jurisprudentie"@nl ;
  skos:altLabel "Zoeken: rechtspraak"@nl ;
  skos:definition "Het doorzoeken en ontsluiten van jurisprudentie (uitspraken), inclusief filtering, citaties, vindplaatsen en relevante overwegingen."@nl
.

lt:ZoekenWetgeving a skos:Concept ;
  skos:inScheme lt:BegrippenkaderCategorieen ;
  # skos:prefLabel "Search: legislation"@en ;
  skos:prefLabel "Zoeken: wet- en regelgeving"@nl ;
  skos:altLabel "Zoeken: wetgeving"@nl ;
  skos:definition "Het doorzoeken en ontsluiten van wet- en regelgeving, inclusief consolidaties, historische versies, artikelen/leden en kruisverwijzingen."@nl
.

# SHACL shape for functionaliteiten
lto:FunctionaliteitenShape a sh:NodeShape;
  rdfs:label "Functionaliteiten";
  sh:property [
    sh:path [sh:inversePath skos:member];
    sh:hasValue lto:Functionaliteiten
  ]
.

