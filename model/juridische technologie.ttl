lt:Gesloten a skos:Concept;

  skos:inScheme lt:BegrippenkaderCategorieen;
  skos:prefLabel "Gesloten"@nl;
  rdfs:label "Gesloten"@nl;
.

# SHACL shape to validate usage of licentievorm property

lto:LicentievormenShape a sh:NodeShape;
  rdfs:label "Licentievormen";
  sh:property [
    sh:path [sh:inversePath skos:member];
    sh:hasValue lto:Licentievormen
  ]

.

