  skos:inScheme lto:BegrippenkaderProducten;
  skosthes:broaderGeneric lto:Product;
  lto:outputVanTaak ltt:GeautomatiseerdeRegeluitvoering;
  lto:inputVoorTaak ltt:Evaluatie;
.

