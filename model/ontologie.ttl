@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

@prefix lt: <http://bp4mc2.org/lt/>.
@prefix lto: <http://bp4mc2.org/lto#>.

lto:JuridischeTechnologie a sh:NodeShape, owl:Class;
  rdfs:label "Juridische technologie";
  dct:subject lt:JuridischeTechnologie;
  sh:property [
    sh:order 1;
    rdfs:label "naam";
    sh:path lto:naam;
    sh:description "De naam van de technologie";
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string;
  ];
  sh:property [
    sh:order 2;
    rdfs:label "omschrijving";
    sh:path lto:omschrijving;
    sh:description "Een omschrijving van de technologie";
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string;
  ];
  sh:property [
    sh:order 3;
    rdfs:label "gebruiksstatus";
    sh:path lto:gebruiksstatus;
    sh:description "De status  van het gebruik van de technologie (nog in ontwikkeling, een voorstel, in gebruik, etc)";
    sh:minCount 1;
    sh:maxCount 1;
    sh:node lto:Gebruiksstatussen;
    sh:datatype xsd:string;
  ];
  sh:property [
    sh:order 4;
    rdfs:label "licentievorm";
    sh:path lto:licentievorm;
    sh:description "De mate waarin de technologie vrij is te gebruiken";
    sh:minCount 1;
    sh:maxCount 1;
    sh:node lto:Licentievormen;
  ];
  sh:property [
    sh:order 5;
    rdfs:label "geboden functionaliteit";
    sh:path lto:gebodenFunctionaliteit;
    sh:description "Het soort functionaliteit dat de technologie biedt";
    sh:minCount 1;
    sh:node lto:Functionaliteiten;
  ];
  sh:property [
    sh:order 6;
    rdfs:label "beoogde gebruikers";
    sh:path lto:beoogdeGebruikers;
    sh:description "De groep van gebruikers die van deze technologie gebruik zou kunnen maken";
    sh:minCount 1;
    sh:node lto:Gebruikersgroepen;
  ];
  sh:property [
    sh:order 7;
    rdfs:label "bijgewerkt op";
    sh:path lto:bijgewerktOp;
    sh:description "De datum waarop de beschrijving van de technologie voor het laatst is bijgewerkt";
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:date;
  ];
  sh:property [
    sh:order 8;
    rdfs:label "ondersteuning voor";
    sh:path lto:ondersteuningVoor;
    sh:description "Het beschouwingsniveau en de modelsoort waarvoor de technologie ondersteuning biedt";
    sh:minCount 1;
    sh:node lto:Ondersteuningsvorm;
    sh:nodeKind sh:BlankNode;
  ];
  sh:property [
    sh:order 100;
    rdfs:label "geschikt voor taak";
    sh:path lto:geschiktVoorTaak;
    sh:description "Relateert de technologie aan het taaktype waarvoor de technologie kan worden ingezet";
    sh:minCount 1;
    sh:class lto:Taakinvulling
  ];
  sh:property [
    sh:order 101;
    rdfs:label "beschrijving";
    sh:path lto:beschrijving;
    sh:minCount 1;
    sh:maxCount 1;
    sh:nodeKind sh:BlankNode;
    sh:node lto:Documentatie
  ];
  sh:property [
    sh:order 102;
    rdfs:label "aanvullende documentatie";
    sh:path lto:bron;
    sh:class lto:Bronverwijzing
  ]
.

lto:Gebruiksstatussen a sh:NodeShape;
  sh:name "Gebruiksstatussen";
  sh:property [
    sh:path skos:inScheme;
    sh:hasValue lt:Gebruiksstatussen;
  ]
.
lt:WorkInProgress a skos:Concept;
  rdfs:label "Work in progress";
  skos:inScheme lt:Gebruiksstatussen;
.
lt:Voorstel a skos:Concept;
  rdfs:label "Voorstel";
  skos:inScheme lt:Gebruiksstatussen;
.
lt:InGebruik a skos:Concept;
  rdfs:label "In gebruik";
  skos:inScheme lt:Gebruiksstatussen;
.

lto:Licentievormen a sh:NodeShape;
  sh:name "Licentievormen";
  sh:property [
    sh:path skos:inScheme;
    sh:hasValue lt:Licentievormen;
  ]
.
lt:VolledigOpen a skos:Concept;
  rdfs:label "Volledig open";
  skos:inScheme lt:Licentievormen;
.
lt:OpenOnderVoorwaarden a skos:Concept;
  rdfs:label "Open onder voorwaarden";
  skos:inScheme lt:Licentievormen;
.
lt:Gesloten a skos:Concept;
  rdfs:label "Gesloten";
  skos:inScheme lt:Licentievormen;
.

lto:Functionaliteiten a sh:NodeShape;
  sh:name "Functionaliteiten";
  sh:property [
    sh:path skos:inScheme;
    sh:hasValue lt:Functionaliteiten;
  ]
.

lto:Gebruikersgroepen a sh:NodeShape;
  sh:name "Gebruikersgroepen";
  sh:property [
    sh:path skos:inScheme;
    sh:hasValue lt:Gebruikersgroepen;
  ]
.
lt:BurgersEnBedrijven a skos:Concept;
  rdfs:label "Burgers en bedrijven";
  skos:inScheme lt:Gebruikersgroepen;
.

lto:Ondersteuningsvorm a sh:NodeShape;
  sh:name "Ondersteuningsvorm";
  sh:property [
    sh:order 1;
    rdfs:label "beschouwingsniveau";
    sh:path lto:beschouwingsniveau;
    sh:minCount 1;
    sh:node lto:Beschouwingsniveaus
  ];
  sh:property [
    sh:order 2;
    rdfs:label "modelsoort";
    sh:path lto:modelsoort;
    sh:minCount 1;
    sh:node lto:Modelsoorten;
  ]
.
lto:Beschouwingsniveaus a sh:NodeShape;
  sh:name "Beschouwingsniveaus";
  sh:property [
    sh:path skos:inScheme;
    sh:hasValue lt:Beschouwingsniveaus
  ]
.
lt:Tekstueel a skos:Concept;
  rdfs:label "Tekstueel";
  skos:inScheme lt:Beschouwingsniveaus
.
lt:Semantisch a skos:Concept;
  rdfs:label "Semantisch";
  skos:inScheme lt:Beschouwingsniveaus
.
lt:Ontologisch a skos:Concept;
  rdfs:label "Ontologisch";
  skos:inScheme lt:Beschouwingsniveaus
.
lt:Logisch a skos:Concept;
  rdfs:label "Logisch";
  skos:inScheme lt:Beschouwingsniveaus
.
lt:Technisch a skos:Concept;
  rdfs:label "Technisch";
  skos:inScheme lt:Beschouwingsniveaus
.
lto:Modelsoorten a sh:NodeShape;
  sh:name "Modelsoorten";
  sh:property [
    sh:path skos:inScheme;
    sh:hasValue lt:Modelsoorten
  ]
.
lt:Descriptief a skos:Concept;
  rdfs:label "Descriptief";
  skos:inScheme lt:Modelsoorten
.
lt:Normatief a skos:Concept;
  rdfs:label "Normatief";
  skos:inScheme lt:Modelsoorten
.

lto:naam a owl:DatatypeProperty;
  rdfs:label "naam";
.
lto:omschrijving a owl:DatatypeProperty;
  rdfs:label "omschrijving";
.
lto:gebruiksstatus a owl:ObjectProperty;
  rdfs:label "gebruiksstatus";
  rdfs:range skos:Concept;
.
lto:licentievorm a owl:ObjectProperty;
  rdfs:label "licentievorm";
  rdfs:range skos:Concept;
.
lto:gebodenFunctionaliteit a owl:ObjectProperty;
  rdfs:label "geboden functionaliteit";
  rdfs:range skos:Concept;
.
lto:beoogdeGebruikers a owl:ObjectProperty;
  rdfs:label "beoogde gebruikers";
  rdfs:range skos:Concept;
.
lto:ondersteuningVoor a owl:ObjectProperty;
  rdfs:label "ondersteuning voor";
.
lto:beschouwingsniveau a owl:ObjectProperty;
  rdfs:label "beschouwingsniveau";
  rdfs:range skos:Concept;
.
lto:modelsoort a owl:ObjectProperty;
  rdfs:label "modelsoort";
  rdfs:range skos:Concept;
.

lto:Methode a sh:NodeShape, owl:Class;
  rdfs:label "Methode";
  rdfs:subClassOf lto:JuridischeTechnologie;
  dct:subject lt:Methode;
  sh:property [
    sh:order 1;
    rdfs:label "beheerder";
    sh:path lto:beheerder;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class lto:Organisatie
  ]
.

lto:beheerder a owl:ObjectProperty;
  rdfs:label "beheerder";
  rdfs:range lto:Organisatie
.
lto:leverancier a owl:ObjectProperty;
  rdfs:label "leverancier";
  rdfs:range lto:Organisatie
.

lto:Standaard a sh:NodeShape, owl:Class;
  rdfs:label "Standaard";
  rdfs:subClassOf lto:JuridischeTechnologie;
  dct:subject lt:Standaard;
  sh:property [
    sh:order 1;
    rdfs:label "beheerder";
    sh:path lto:beheerder;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class lto:Organisatie
  ];
  sh:property [
    sh:order 2;
    rdfs:label "normstatus";
    sh:path lto:normstatus;
    sh:minCount 1;
    sh:maxCount 1;
    sh:node lto:Normstatussen
  ]
.

lto:Normstatussen a sh:NodeShape;
  sh:name "Normstatussen";
  sh:property [
    sh:path skos:inScheme;
    sh:hasValue lt:Normstatussen
  ]
.
lt:Idee a skos:Concept;
  rdfs:label "Idee";
  skos:inScheme lt:Normstatussen
.
lt:Voorstel a skos:Concept;
  rdfs:label "Voorstel";
  skos:inScheme lt:Normstatussen
.
lt:BestPractice a skos:Concept;
  rdfs:label "BestPractice";
  skos:inScheme lt:Normstatussen
.
lt:Industrie a skos:Concept;
  rdfs:label "Industrie";
  skos:inScheme lt:Normstatussen
.
lt:Wettelijk a skos:Concept;
  rdfs:label "Wettelijk";
  skos:inScheme lt:Normstatussen
.

lto:normstatus a owl:ObjectProperty;
  rdfs:label "normstatus";
  rdfs:range skos:Concept
.

lto:Tool a sh:NodeShape, owl:Class;
  rdfs:label "Tool";
  rdfs:subClassOf lto:JuridischeTechnologie;
  dct:subject lt:Standaard;
  sh:property [
    sh:order 1;
    rdfs:label "leverancier";
    sh:path lto:leverancier;
    sh:minCount 1;
    sh:maxCount 1;
    sh:class lto:Organisatie
  ];
  sh:property [
    sh:order 2;
    rdfs:label "type technologie";
    sh:path lto:typeTechnologie;
    sh:minCount 1;
    sh:node lto:Technologietypen;
  ]
.

lto:Technologietypen a sh:NodeShape;
  sh:name "Technologietypen";
  sh:property [
    sh:path skos:inScheme;
    sh:hasValue lt:Technologietypen
  ]
.
lt:MarkupAnnotatie a skos:Concept;
  rdfs:label "Markup (annotatie)";
  skos:inScheme lt:Technologietypen
.
lt:MarkupPublicatie a skos:Concept;
  rdfs:label "Markup (publicatie)";
  skos:inScheme lt:Technologietypen
.
lt:DSL a skos:Concept;
  rdfs:label "DSL";
  skos:inScheme lt:Technologietypen
.
lt:MachineLearning a skos:Concept;
  rdfs:label "Machine learning";
  skos:inScheme lt:Technologietypen
.
lt:Regelexecutie a skos:Concept;
  rdfs:label "Regelexecutie";
  skos:inScheme lt:Technologietypen
.

lto:typeTechnologie a owl:ObjectProperty;
  rdfs:label "type technologie";
  rdfs:range skos:Concept
.

lto:Taakinvulling a sh:NodeShape, owl:Class;
  rdfs:label "Taakinvulling";
  dct:subject lt:Taakinvulling;
  sh:property [
    sh:order 1;
    rdfs:label "omschrijving";
    sh:path lto:omschrijving;
    sh:description "Een omschrijving hoe de taak wordt ingevuld met behulp van de betreffende technologie";
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string;
  ];
  sh:property [
    sh:order 2;
    rdfs:label "type";
    sh:path lto:taaktype;
    sh:description "Het type taak van deze taakinvulling";
    sh:minCount 1;
    sh:maxCount 1;
    sh:node lto:Taaktypen;
  ]
.

lto:Taaktypen a sh:NodeShape;
  sh:name "Taaktypen";
  sh:property [
    sh:path skos:inScheme;
    sh:hasValue lt:Taaktypen
  ]
.
lt:OpstellenRegeltekst skos:inScheme lt:Taaktypen.

lto:Documentatie a sh:NodeShape;
  rdfs:label "Documentatie";
  sh:property [
    sh:order 1;
    rdfs:label "Beoogd gebruik";
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:markdown
  ];
.

lto:Bronverwijzing a sh:NodeShape;
  rdfs:label "Bronverwijzing";
  sh:property [
    sh:order 1;
    rdfs:label "titel";
    sh:path dct:title;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string
  ];
  sh:property [
    sh:order 2;
    rdfs:label "locatie";
    sh:path foaf:page;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:anyURI
  ];
  sh:property [
    sh:order 3;
    rdfs:label "verwijzing";
    sh:path dct:bibliographicCitation;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string
  ];
.
